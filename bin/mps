#!/usr/bin/env bash
# shellcheck disable=SC2154  # color vars defined in lib/common.sh
set -euo pipefail

# Multi Pass Sandbox (mps) — Main entry point
# https://github.com/HorizenLabs/multipass-sandbox

# Resolve install directory
# Portable canonical path resolution (BSD readlink lacks -f)
_mps_source="${BASH_SOURCE[0]}"
while [[ -L "$_mps_source" ]]; do
    _mps_dir="$(cd -P "$(dirname "$_mps_source")" && pwd)"
    _mps_source="$(readlink "$_mps_source")"
    [[ "$_mps_source" != /* ]] && _mps_source="${_mps_dir}/${_mps_source}"
done
MPS_ROOT="$(cd -P "$(dirname "$_mps_source")/.." && pwd)"
unset _mps_source _mps_dir
export MPS_ROOT

# ---------- Fast-path: tab-completion (skip config/deps/update check) ----------

_mps_dispatch_complete() {
    local action="${1:-}"
    shift 2>/dev/null || true

    case "$action" in
        commands)
            # List command names from commands/*.sh basenames
            local f
            for f in "${MPS_ROOT}"/commands/*.sh; do
                [[ -f "$f" ]] || continue
                local name
                name="$(basename "$f" .sh)"
                echo "$name"
            done
            ;;
        instances)
            # Dynamic: query multipass for mps- prefixed instance short names
            local prefix="${MPS_INSTANCE_PREFIX:-mps}"
            if command -v multipass &>/dev/null && command -v jq &>/dev/null; then
                multipass list --format json 2>/dev/null | \
                    jq -r --arg pfx "${prefix}-" \
                    '.list[]? | select(.name | startswith($pfx)) | .name | ltrimstr($pfx)' 2>/dev/null
            fi
            ;;
        profiles)
            # Static: profile names from templates/profiles/*.env
            local f
            for f in "${MPS_ROOT}"/templates/profiles/*.env; do
                [[ -f "$f" ]] || continue
                basename "$f" .env
            done
            ;;
        images)
            # Image flavor names from layers + cached images
            local seen=""
            local f
            for f in "${MPS_ROOT}"/images/layers/*.yaml; do
                [[ -f "$f" ]] || continue
                local name
                name="$(basename "$f" .yaml)"
                echo "$name"
                seen="${seen} ${name}"
            done
            # Also include cached image names not in layers
            local cache_dir="${HOME}/mps/cache/images"
            if [[ -d "$cache_dir" ]]; then
                local d
                for d in "$cache_dir"/*/; do
                    [[ -d "$d" ]] || continue
                    local name
                    name="$(basename "$d")"
                    case " ${seen} " in
                        *" ${name} "*) ;;
                        *) echo "$name" ;;
                    esac
                done
            fi
            ;;
        cloud_init)
            # Template names from project + personal cloud-init dirs
            local f
            for f in "${MPS_ROOT}"/templates/cloud-init/*.yaml; do
                [[ -f "$f" ]] || continue
                basename "$f" .yaml
            done
            local user_dir="${HOME}/mps/cloud-init"
            if [[ -d "$user_dir" ]]; then
                for f in "$user_dir"/*.yaml; do
                    [[ -f "$f" ]] || continue
                    basename "$f" .yaml
                done
            fi
            ;;
        *)
            # Command-level completion: flags, subcmds, flag-values
            # action is the command name; remaining args are the query
            local cmd="$action"
            local query="${1:-}"
            shift 2>/dev/null || true

            # Normalize command name for function lookup (ssh-config -> ssh_config)
            local func_name="_complete_${cmd//-/_}"

            # Source the command file to get its _complete_* function
            local cmd_script="${MPS_ROOT}/commands/${cmd}.sh"
            [[ -f "$cmd_script" ]] || return 0

            # shellcheck source=/dev/null
            source "$cmd_script"

            # Check function exists
            if ! declare -f "$func_name" &>/dev/null; then
                return 0
            fi

            # Dispatch: flags, subcmds, flag-values
            case "$query" in
                flags)
                    # For subcommand-aware commands: mps __complete image flags pull
                    "$func_name" flags "${1:-}"
                    ;;
                subcmds)
                    "$func_name" subcmds
                    ;;
                flag-values)
                    # mps __complete <cmd> flag-values <flag>
                    # or: mps __complete <cmd> <subcmd> flag-values <flag>
                    "$func_name" flag-values "${1:-}"
                    ;;
                *)
                    # query might be a subcommand: mps __complete image pull flags
                    local subcmd="$query"
                    local sub_query="${1:-}"
                    shift 2>/dev/null || true
                    case "$sub_query" in
                        flags)
                            "$func_name" flags "$subcmd"
                            ;;
                        flag-values)
                            "$func_name" flag-values "${1:-}"
                            ;;
                        *)
                            # Unknown query — no output
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

if [[ "${1:-}" == "__complete" ]]; then
    shift
    _mps_dispatch_complete "$@"
    exit 0
fi

# Read version from VERSION file (single source of truth)
MPS_VERSION="$(cat "${MPS_ROOT}/VERSION" 2>/dev/null || echo "unknown")"
MPS_VERSION="${MPS_VERSION%$'\n'}"

# Store the directory where mps was invoked
MPS_PROJECT_DIR="$(pwd)"
export MPS_PROJECT_DIR

# Source shared libraries
# shellcheck source=../lib/common.sh
source "${MPS_ROOT}/lib/common.sh"
# shellcheck source=../lib/multipass.sh
source "${MPS_ROOT}/lib/multipass.sh"

# ---------- Help ----------

mps_usage() {
    cat <<EOF
${_color_bold}Multi Pass Sandbox (mps)${_color_reset} v${MPS_VERSION}
Isolated VM-based development environments powered by Multipass.

${_color_bold}Usage:${_color_reset}
    mps <command> [options]

${_color_bold}Commands:${_color_reset}
    create [flags]              Create a new sandbox
    up [flags]                  Create (if needed) and start a sandbox
    down [--name <name>]        Stop a sandbox
    destroy [--name <name>]     Remove a sandbox permanently
    shell [--name <name>]       Open an interactive shell in a sandbox
    exec [--name <name>] -- ..  Execute a command in a sandbox
    transfer <src...> <dst>     Transfer files between host and sandbox
    list                        List all sandboxes
    status [--name <name>]      Show detailed sandbox status
    ssh-config [--name <name>]  Generate SSH config for VS Code integration
    image <subcommand>          Manage sandbox images (list, pull, import, remove)
    mount <subcommand>          Manage mounts (add, remove, list)
    port <subcommand>           Manage port forwarding

${_color_bold}Options:${_color_reset}
    --help, -h             Show this help message
    --version, -v          Show version
    --debug                Enable debug logging

${_color_bold}Examples:${_color_reset}
    mps up                                  Start sandbox, auto-name from CWD
    mps up --name mydev                     Start sandbox with explicit name
    mps create --profile heavy --cpus 8 --memory 16G
    mps shell --name mydev                  Open shell in sandbox
    mps exec --name mydev -- docker ps      Run command in sandbox
    mps transfer ./f.txt :/home/ubuntu/     Copy file into sandbox
    mps ssh-config --name mydev --append
    mps destroy --name mydev --force

${_color_bold}Configuration:${_color_reset}
    Config files are loaded in order (later wins):
      1. <mps-root>/config/defaults.env
      2. ~/mps/config
      3. .mps.env (per-project)
      4. CLI flags

EOF
}

# ---------- Dispatch ----------

main() {
    # Handle global flags first
    local command=""
    local -a args=()

    for arg in "$@"; do
        case "$arg" in
            --help|-h)
                if [[ -z "$command" ]]; then
                    mps_usage
                    exit 0
                else
                    args+=("$arg")
                fi
                ;;
            --version|-v)
                if [[ -z "$command" ]]; then
                    echo "mps version ${MPS_VERSION}"
                    exit 0
                else
                    args+=("$arg")
                fi
                ;;
            --debug)
                export MPS_DEBUG=true
                ;;
            *)
                if [[ -z "$command" ]]; then
                    command="$arg"
                else
                    args+=("$arg")
                fi
                ;;
        esac
    done

    if [[ -z "$command" ]]; then
        mps_usage
        exit 1
    fi

    # Load config cascade
    mps_load_config

    # Background update check (silent, non-blocking)
    _mps_check_cli_update

    # Skip dependency check if subcommand is --help
    local needs_deps=true
    for a in ${args[@]+"${args[@]}"}; do
        if [[ "$a" == "--help" || "$a" == "-h" ]]; then
            needs_deps=false
            break
        fi
    done
    if [[ "$needs_deps" == "true" ]]; then
        mps_check_deps
    fi

    # Validate command name (prevent path traversal via ../ or special chars)
    if [[ ! "$command" =~ ^[a-z][-a-z]*$ ]]; then
        mps_log_error "Unknown command: '$command'"
        echo ""
        mps_usage
        exit 1
    fi

    # Dispatch to command script
    local cmd_script="${MPS_ROOT}/commands/${command}.sh"
    if [[ ! -f "$cmd_script" ]]; then
        mps_log_error "Unknown command: '$command'"
        echo ""
        mps_usage
        exit 1
    fi

    # shellcheck source=/dev/null
    source "$cmd_script"

    # Call the command's main function: cmd_<command>
    local cmd_func="cmd_${command//-/_}"
    if ! declare -f "$cmd_func" &>/dev/null; then
        mps_die "Command script '$cmd_script' does not define function '$cmd_func'"
    fi

    "$cmd_func" ${args[@]+"${args[@]}"}
}

main "$@"
