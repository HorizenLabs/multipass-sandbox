# Multi Pass Sandbox (mps) — Default Configuration
# Override in ~/.mps/config (global) or .mps.env (per-project)

# VM defaults
# MPS_DEFAULT_IMAGE accepts mps image names (base, base:1.0.0) or Ubuntu versions (24.04)
# When set to an mps image name, auto-pull is attempted if the image is not cached locally.
MPS_DEFAULT_IMAGE=base
MPS_DEFAULT_CPUS=2
MPS_DEFAULT_MEMORY=2G
MPS_DEFAULT_DISK=20G
MPS_DEFAULT_PROFILE=lite
MPS_DEFAULT_CLOUD_INIT=default

# Mount defaults
MPS_NO_AUTOMOUNT=false

# Port forwarding (space-separated host:guest pairs, auto-forwarded on up/create)
MPS_PORTS=""

# Image distribution (public URL, served via Cloudflare proxy over Backblaze B2)
MPS_IMAGE_BASE_URL=https://mpsandbox.horizenlabs.io

# Backblaze B2 upload settings (used by image build/publish scripts only)
MPS_B2_BUCKET=mpsandbox

# Instance naming
MPS_INSTANCE_PREFIX=mps

# SSH (empty = auto-detect from ~/.ssh/)
MPS_SSH_KEY=
