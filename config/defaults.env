# Multi Pass Sandbox (mps) — Default Configuration
# Override in ~/.mps/config (global) or .mps.env (per-project)

# VM defaults
# MPS_DEFAULT_IMAGE accepts Ubuntu versions (24.04) or mps image names (base, base:1.0.0)
MPS_DEFAULT_IMAGE=24.04
MPS_DEFAULT_CPUS=4
MPS_DEFAULT_MEMORY=4G
MPS_DEFAULT_DISK=50G
MPS_DEFAULT_PROFILE=standard
MPS_DEFAULT_CLOUD_INIT=base

# Mount defaults
MPS_MOUNT_CWD=true
MPS_NO_AUTOMOUNT=false

# Port forwarding (space-separated host:guest pairs, auto-forwarded on up/create)
MPS_PORTS=""

# Image distribution (public URL, served via Cloudflare proxy over Backblaze B2)
MPS_IMAGE_BASE_URL=https://images.example.com/mps

# Backblaze B2 upload settings (used by image build/publish scripts only)
MPS_B2_BUCKET=mps-images
MPS_B2_BUCKET_PREFIX=mps

# Instance naming
MPS_INSTANCE_PREFIX=mps

# SSH (empty = auto-detect from ~/.ssh/)
MPS_SSH_KEY=
